{
  "manifest_version": 3,
  "name": "Microsoft Defender for Cloud RBAC Advisor",
  "description": "Surfaces Defender for Cloud RBAC recommendations directly in the Azure Portal with actionable fixes.",
  "version": "0.1.0",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["https://portal.azure.com/*"],
  "content_scripts": [
    {
      "matches": ["https://portal.azure.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay.css"],
      "matches": ["https://portal.azure.com/*"]
    }
  ]
}
